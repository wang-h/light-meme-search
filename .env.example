# 本地开发可 copy 为 .env；生产由 mac-mini-deploy 注入
DATABASE_URL=postgresql://admin:password@localhost:5432/meme_search?schema=public

# 访问控制（均可选；亦可在站内「设置」写入数据库，DB 优先于下方环境变量）
# MEME_SITE_PASSWORD=
# MEME_API_KEY=
# MEME_SESSION_SECRET=
# 冷启动/应急：可配合 PUT /api/admin/settings 的 X-Admin-Token
# MEME_BOOTSTRAP_TOKEN=

MEME_IMAGE_BASE_URL=
VOLCENGINE_ARK_API_KEY=
VOLCENGINE_ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
MEME_EMBEDDING_MODEL=doubao-embedding-vision-251215
PORT=3000
